{
  "title": "AccessGuard - API Overview",
  "uid": "accessguard-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requêtes par seconde (par endpoint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Taux d'erreurs (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latence p95 (secondes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Requêtes en cours (in-flight)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_requests_inprogress)",
          "legendFormat": "in-progress"
        }
      ]
    },
    {
      "id": 5,
      "title": "Disponibilité API (up)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "up{job=\"accessguard-api\"}",
          "legendFormat": "up"
        }
      ]
    }
  ]
}
